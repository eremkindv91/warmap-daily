{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eremkindv91.github.io/warmap-daily/schemas/snapshot.schema.json",
  "title": "WarMap Daily control snapshot",
  "type": "object",
  "required": ["type", "metadata", "features"],
  "properties": {
    "type": {"const": "FeatureCollection"},
    "metadata": {
      "type": "object",
      "required": ["snapshot_date", "methodology_version", "moderation_status"],
      "properties": {
        "snapshot_date": {"type": ["string", "null"], "format": "date"},
        "methodology_version": {"type": "string"},
        "moderation_status": {"enum": ["not_published", "approved", "published"]}
      }
    },
    "features": {"type": "array", "items": {"$ref": "#/$defs/controlFeature"}}
  },
  "$defs": {
    "controlFeature": {
      "type": "object",
      "required": ["type", "properties", "geometry"],
      "properties": {
        "type": {"const": "Feature"},
        "properties": {
          "type": "object",
          "required": ["id", "name", "status", "valid_from", "confidence", "evidence_ids", "source_ids", "moderation"],
          "properties": {
            "id": {"type": "string", "minLength": 1},
            "name": {"type": "string", "minLength": 1},
            "status": {"enum": ["control_ru", "control_ua", "contested", "unknown"]},
            "valid_from": {"type": "string", "format": "date-time"},
            "confidence": {"type": "number", "minimum": 0.93, "maximum": 1},
            "evidence_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
            "source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
            "moderation": {
              "type": "object",
              "required": ["decision", "reviewer", "reviewed_at", "rationale"],
              "properties": {
                "decision": {"const": "approved"},
                "reviewer": {"type": "string", "minLength": 1},
                "reviewed_at": {"type": "string", "format": "date-time"},
                "rationale": {"type": "string", "minLength": 1}
              }
            }
          }
        },
        "geometry": {"type": "object"}
      }
    }
  }
}
